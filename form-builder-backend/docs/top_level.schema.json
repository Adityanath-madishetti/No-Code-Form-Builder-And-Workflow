{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "FormSchema",
    "type": "object",
    "required": [
        "formId",
        "version",
        "meta",
        "settings",
        "pages",
        "components"
    ],
    "properties": {
        "formId": {
            "type": "string"
        },
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "status": {
            "type": "string",
            "enum": [
                "draft",
                "published",
                "archived"
            ]
        },
        "meta": {
            "$ref": "./meta.schema.json"
        },
        "settings": {
            "$ref": "./settings.schema.json"
        },
        "theme": {
            "$ref": "./theme.schema.json"
        },
        "pages": {
            "type": "array",
            "items": {
                "$ref": "./page.schema.json"
            }
        },
        "components": {
            "type": "array",
            "items": {
                "$ref": "./components.schema.json"
            }
        },
        "logic": {
            "$ref": "./logic.schema.json"
        },
        "workflow": {
            "$ref": "./workflow.schema.json"
        },
        "versions": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/version"
            }
        }
    },
    "definitions": {
        "version": {
            "type": "object",
            "required": [
                "version",
                "createdAt"
            ],
            "properties": {
                "version": {
                    "type": "integer"
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "authorId": {
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                }
            }
        }
    }
}

