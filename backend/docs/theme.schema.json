{"theme": {
  "themeId": "uuid-of-global-theme",   // if using a saved theme
  "overrides": {                        // form-level overrides on top of global theme
    "global": {
      "fontFamily": "Inter, sans-serif",
      "fontSize": "16px",
      "primaryColor": "#4F46E5",
      "backgroundColor": "#FFFFFF",
      "textColor": "#111827",
      "borderRadius": "8px",
      "mode": "light"                   // "light" | "dark"
    },
    "header": {
      "backgroundColor": "#4F46E5",
      "textColor": "#FFFFFF",
      "logoUrl": null
    },
    "button": {
      "backgroundColor": "#4F46E5",
      "textColor": "#FFFFFF",
      "hoverColor": "#4338CA",
      "borderRadius": "6px"
    },
    "input": {
      "borderColor": "#D1D5DB",
      "focusColor": "#4F46E5",
      "backgroundColor": "#F9FAFB",
      "errorColor": "#EF4444"
    }
  }
}}